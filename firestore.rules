rules_version = '2';

// Deny-all: clients never touch Firestore directly. Every read and write
// goes through the server (Firebase Admin SDK via ADC), which bypasses these
// rules. This is defense in depth — a leaked client config grants no data access.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
