# ---------------------------------------------------------------------------
# Delta environment variables. Copy to .env.local and fill in.
# NEVER commit real values. The Gemini key lives in Secret Manager in prod.
# ---------------------------------------------------------------------------

# --- Firebase web config (client-side, safe to expose, NEXT_PUBLIC_*) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Server-side secrets (NEVER prefixed NEXT_PUBLIC) ---
# Gemini API key from Google AI Studio. In production this is injected from
# Secret Manager (--set-secrets GEMINI_API_KEY=gemini-api-key:latest).
GEMINI_API_KEY=

# --- Firebase Admin ---
# On Cloud Run this is unset and Application Default Credentials are used.
# For local dev, point at a downloaded service-account key (gitignored).
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=

# --- Feature flags ---
# Set to "1" to hard-disable all AI routes (forces deterministic fallbacks).
AI_DISABLED=
# Set to "1" in E2E/test environments.
DELTA_E2E=
