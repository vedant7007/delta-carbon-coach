    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toast": "1.2.6",
    "@radix-ui/react-tooltip": "1.1.8",
    "clsx": "2.1.1",
    "firebase": "11.3.1",
    "firebase-admin": "13.4.0",
    "next": "15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "2.15.1",
    "tailwind-merge": "3.0.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
